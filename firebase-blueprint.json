{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "User's profile photo URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" },
        "lastLogin": { "type": "string", "format": "date-time", "description": "Last login timestamp" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role" }
      },
      "required": ["uid", "email"]
    },
    "Asset": {
      "title": "Asset",
      "description": "An archival asset requiring clearance",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique asset ID" },
        "uid": { "type": "string", "description": "Owner's user ID" },
        "asset_name": { "type": "string", "description": "Name of the asset" },
        "asset_type": { "type": "string", "enum": ["Video", "Image", "Audio"], "description": "Type of asset" },
        "detected_source": { "type": "string", "description": "Source of the asset" },
        "copyright_status": { "type": "string", "enum": ["Public Domain", "Cleared", "Creative Commons", "Orphan Work", "Copyrighted"], "description": "Current copyright status" },
        "risk_level": { "type": "string", "enum": ["Low", "Medium", "High"], "description": "Clearance risk level" },
        "workflow_stage": { "type": "string", "enum": ["Backlog", "Searching", "Pending Response", "Cleared", "Rejected"], "description": "Current stage in clearance workflow" },
        "thumbnail_url": { "type": "string", "description": "URL to asset thumbnail" },
        "ai_confidence_score": { "type": "number", "description": "AI confidence in status assessment" },
        "last_updated": { "type": "string", "format": "date-time", "description": "Last update timestamp" },
        "rights_holder": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "contact_status": { "type": "string" }
          }
        }
      },
      "required": ["uid", "asset_name", "asset_type", "copyright_status", "workflow_stage"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/assets/{assetId}": {
      "schema": "Asset",
      "description": "Archival assets collection"
    }
  }
}
